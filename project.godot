; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Space23"
config/description="Music-driven vertical shoot-'em-up. Click to play."
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://saturn.png"
# Boot splash: la nave procedurale che brilla su nero. boot.png è una
# rasterizzazione di boot.svg disegnato matching le coordinate del
# ship_renderer reale (NOSE, WINGS, ENGINES) con glow filter.
boot_splash/show_image=true
boot_splash/image="res://boot.png"
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/use_filter=true
# fullsize=true: scala l'immagine per fillare l'intero viewport (con bg_color
# nelle eventuali bande di letterboxing). Senza, l'immagine 1280×1280 veniva
# centrata in un canvas più piccolo e il browser body color (white) si vedeva
# attorno.
boot_splash/fullsize=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[audio]

# Bus layout definito come risorsa (default_bus_layout.tres) invece che creato
# runtime via AudioServer.add_bus(). Workaround per il bug noto di Godot 4 web
# export, dove i bus aggiunti via codice non vengono routati e l'audio resta
# silente: https://github.com/godotengine/godot/issues/115560
buses/default_bus_layout="res://default_bus_layout.tres"

[rendering]

environment/defaults/default_clear_color=Color(0, 0, 0, 1)
# Free win 1: 2D MSAA 2× — smussa la geometria procedurale (nave, ali,
# asteroidi, costellazioni). Costo trascurabile in 2D; fa la differenza
# sui contorni delle polyline HDR.
anti_aliasing/quality/msaa_2d=1
# Free win 2: Screen-space FXAA — cattura i bordi residui dello shader
# output. ~0.5ms sul web, tutta la nebula resta soft.
anti_aliasing/quality/screen_space_aa=1
# Free win 3 (CRITICO per local-vs-web): HDR rendering anche su WebGL
# Compatibility. Senza questo, i colori HDR (cockpit (2.5,0.8,3.5),
# explosion (10,10,10), bullet (0.2,1.5,3.0)) vengono CLIPPATI a 1.0 in
# Compatibility → bloom non triggera, web sembra "spento" rispetto al
# Forward+ desktop. Con questo, HDR è preservato e il glow funziona
# uniformemente.
viewport/hdr_2d=true
